# Environment Variables for Link AI Chat
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (Required)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Optional: Custom port (default is 5000)
# PORT=5000

# Optional: Database URL (if using external database)
# DATABASE_URL=sqlite:///users.db

# Next.js Configuration
NEXT_PUBLIC_APP_NAME=Link AI Chat
NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: Firebase Configuration (for future authentication features)
# FIREBASE_API_KEY=your_firebase_api_key
# FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# FIREBASE_APP_ID=your_app_id